[
  {"id": 1, "text": "Am the life of the party.", "text_zh": "我是聚会中的活跃人物。", "trait": "E", "reverse": false},
  {"id": 2, "text": "Feel little concern for others.", "text_zh": "我很少关心他人。", "trait": "A", "reverse": true},
  {"id": 3, "text": "Am always prepared.", "text_zh": "我总是有准备。", "trait": "C", "reverse": false},
  {"id": 4, "text": "Get stressed out easily.", "text_zh": "我很容易感到压力。", "trait": "N", "reverse": false},
  {"id": 5, "text": "Have a rich vocabulary.", "text_zh": "我的词汇量很丰富。", "trait": "O", "reverse": false},
  {"id": 6, "text": "Don't talk a lot.", "text_zh": "我不太多话。", "trait": "E", "reverse": true},
  {"id": 7, "text": "Am interested in people.", "text_zh": "我对他人很感兴趣。", "trait": "A", "reverse": false},
  {"id": 8, "text": "Leave my belongings around.", "text_zh": "我常把物品随手乱放。", "trait": "C", "reverse": true},
  {"id": 9, "text": "Am relaxed most of the time.", "text_zh": "大多数时候我都很放松。", "trait": "N", "reverse": true},
  {"id": 10, "text": "Have difficulty understanding abstract ideas.", "text_zh": "我理解抽象概念有困难。", "trait": "O", "reverse": true},

  {"id": 11, "text": "Feel comfortable around people.", "text_zh": "我在他人身边感到自在。", "trait": "E", "reverse": false},
  {"id": 12, "text": "Insult people.", "text_zh": "我会冒犯他人。", "trait": "A", "reverse": true},
  {"id": 13, "text": "Pay attention to details.", "text_zh": "我注重细节。", "trait": "C", "reverse": false},
  {"id": 14, "text": "Worry about things.", "text_zh": "我经常为事情担心。", "trait": "N", "reverse": false},
  {"id": 15, "text": "Have a vivid imagination.", "text_zh": "我有生动的想象力。", "trait": "O", "reverse": false},
  {"id": 16, "text": "Keep in the background.", "text_zh": "我通常保持低调、不显眼。", "trait": "E", "reverse": true},
  {"id": 17, "text": "Sympathize with others' feelings.", "text_zh": "我能同情他人的感受。", "trait": "A", "reverse": false},
  {"id": 18, "text": "Make a mess of things.", "text_zh": "我常把事情弄得一团糟。", "trait": "C", "reverse": true},
  {"id": 19, "text": "Seldom feel blue.", "text_zh": "我很少感到情绪低落。", "trait": "N", "reverse": true},
  {"id": 20, "text": "Am not interested in abstract ideas.", "text_zh": "我对抽象概念不感兴趣。", "trait": "O", "reverse": true},

  {"id": 21, "text": "Start conversations.", "text_zh": "我会主动开启对话。", "trait": "E", "reverse": false},
  {"id": 22, "text": "Am not interested in other people's problems.", "text_zh": "我对他人的问题不感兴趣。", "trait": "A", "reverse": true},
  {"id": 23, "text": "Get chores done right away.", "text_zh": "我会立刻完成该做的事。", "trait": "C", "reverse": false},
  {"id": 24, "text": "Am easily disturbed.", "text_zh": "我容易被打扰、情绪波动。", "trait": "N", "reverse": false},
  {"id": 25, "text": "Have excellent ideas.", "text_zh": "我常有很好的想法。", "trait": "O", "reverse": false},
  {"id": 26, "text": "Have little to say.", "text_zh": "我很少有话可说。", "trait": "E", "reverse": true},
  {"id": 27, "text": "Have a soft heart.", "text_zh": "我心地柔软。", "trait": "A", "reverse": false},
  {"id": 28, "text": "Often forget to put things back in their proper place.", "text_zh": "我常忘记把东西放回原位。", "trait": "C", "reverse": true},
  {"id": 29, "text": "Get upset easily.", "text_zh": "我很容易烦躁/生气。", "trait": "N", "reverse": false},
  {"id": 30, "text": "Do not have a good imagination.", "text_zh": "我的想象力不太好。", "trait": "O", "reverse": true},

  {"id": 31, "text": "Talk to a lot of different people at parties.", "text_zh": "在聚会中我会和很多不同的人交谈。", "trait": "E", "reverse": false},
  {"id": 32, "text": "Am not really interested in others.", "text_zh": "我并不真正关心他人。", "trait": "A", "reverse": true},
  {"id": 33, "text": "Like order.", "text_zh": "我喜欢有条理。", "trait": "C", "reverse": false},
  {"id": 34, "text": "Change my mood a lot.", "text_zh": "我的情绪变化很大。", "trait": "N", "reverse": false},
  {"id": 35, "text": "Am quick to understand things.", "text_zh": "我理解事物很快。", "trait": "O", "reverse": false},
  {"id": 36, "text": "Don't like to draw attention to myself.", "text_zh": "我不喜欢引人注意。", "trait": "E", "reverse": true},
  {"id": 37, "text": "Take time out for others.", "text_zh": "我愿意抽时间帮助他人。", "trait": "A", "reverse": false},
  {"id": 38, "text": "Shirk my duties.", "text_zh": "我会逃避自己的职责。", "trait": "C", "reverse": true},
  {"id": 39, "text": "Have frequent mood swings.", "text_zh": "我经常情绪波动。", "trait": "N", "reverse": false},
  {"id": 40, "text": "Use difficult words.", "text_zh": "我会使用较难的词汇。", "trait": "O", "reverse": false},

  {"id": 41, "text": "Don't mind being the center of attention.", "text_zh": "我不介意成为关注焦点。", "trait": "E", "reverse": false},
  {"id": 42, "text": "Feel others' emotions.", "text_zh": "我能感受到他人的情绪。", "trait": "A", "reverse": false},
  {"id": 43, "text": "Follow a schedule.", "text_zh": "我会按计划表做事。", "trait": "C", "reverse": false},
  {"id": 44, "text": "Get irritated easily.", "text_zh": "我很容易被激怒。", "trait": "N", "reverse": false},
  {"id": 45, "text": "Spend time reflecting on things.", "text_zh": "我会花时间反思事情。", "trait": "O", "reverse": false},
  {"id": 46, "text": "Am quiet around strangers.", "text_zh": "在陌生人面前我比较安静。", "trait": "E", "reverse": true},
  {"id": 47, "text": "Make people feel at ease.", "text_zh": "我能让他人感到自在。", "trait": "A", "reverse": false},
  {"id": 48, "text": "Am exacting in my work.", "text_zh": "我对工作要求严谨。", "trait": "C", "reverse": false},
  {"id": 49, "text": "Often feel blue.", "text_zh": "我经常感到情绪低落。", "trait": "N", "reverse": false},
  {"id": 50, "text": "Am full of ideas.", "text_zh": "我有很多想法。", "trait": "O", "reverse": false}
]
